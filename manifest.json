{
  "manifest_version": 3,
  "name": "Revnu",
  "short_name": "Revnu",
  "version": "1.1.0",
  "description": "Revnu new tab: rotating Revnu wallpapers behind your search bar. AI that sells your software for you — revnu.com",
  "author": "Revnu (revnu.com)",
  "homepage_url": "https://revnu.com",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["search"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Revnu — revnu.com"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
